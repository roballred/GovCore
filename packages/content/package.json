{
  "name": "@govcore/content",
  "version": "0.2.0",
  "description": "Content engine: compile content-type definitions into real Drizzle tables + migrations",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./screens": {
      "types": "./src/screens.tsx",
      "default": "./src/screens.tsx"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@govcore/nextkit": "workspace:*",
    "@govcore/schema": "workspace:*",
    "@govcore/server": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0"
  }
}
