{
  "name": "@govcore/schema",
  "version": "0.3.0",
  "description": "Platform tables, enums, migrations, and the govcore-migrate runner",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "default": "./dist/migrate.js"
    }
  },
  "bin": {
    "govcore-migrate": "./dist/migrate.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.3.0"
  },
  "module": "./dist/index.js",
  "files": [
    "dist",
    "migrations"
  ],
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/migrate.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
