{
  "name": "@govcore/theme",
  "version": "0.1.1",
  "description": "WCAG-AA base theme: design tokens (base.css), a Tailwind preset, and defineTheme with a brand-var allowlist",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./base.css": "./base.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.3.0"
  },
  "module": "./dist/index.js",
  "files": [
    "dist",
    "base.css"
  ],
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
