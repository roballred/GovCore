{
  "name": "@govcore/nextkit",
  "version": "0.8.1",
  "description": "Reusable React: layout primitives + instance-console UI (presentational; data passed as props)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./theming": {
      "types": "./dist/theming.d.ts",
      "default": "./dist/theming.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@govcore/support": "workspace:*",
    "@govcore/theme": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "tsup": "^8.3.0"
  },
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "tsup": {
    "entry": [
      "src/index.tsx",
      "src/theming.tsx",
      "src/client.tsx"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
