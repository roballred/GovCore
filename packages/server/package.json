{
  "name": "@govcore/server",
  "version": "0.1.2",
  "description": "tenantAction — the server-action wrapper that opens the tenant transaction, sets the RLS org GUC, gates on permission, and binds audit",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@govcore/audit": "workspace:*",
    "@govcore/schema": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
