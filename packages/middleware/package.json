{
  "name": "@govcore/middleware",
  "version": "0.1.7",
  "description": "Edge-safe Next.js middleware factory: read-only session decode, resurrection guard, instance/maintenance gating",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@govcore/auth": "workspace:*",
    "next-auth": "^5.0.0-beta.25"
  },
  "peerDependencies": {
    "next": "^15.0.0"
  },
  "devDependencies": {
    "next": "^15.5.0",
    "typescript": "^5.5.0",
    "tsup": "^8.3.0"
  },
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
