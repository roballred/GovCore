{
  "name": "@govcore/auth",
  "version": "0.6.0",
  "description": "Auth.js config factory (createAuth): credentials + injected OIDC, SSO guard, active-membership session, login/logout audit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logout-marker": {
      "types": "./dist/logout-marker.d.ts",
      "default": "./dist/logout-marker.js"
    },
    "./password": {
      "types": "./dist/password.d.ts",
      "default": "./dist/password.js"
    },
    "./next-auth": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./password-flows": {
      "types": "./dist/password-flows.d.ts",
      "default": "./dist/password-flows.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.4.0",
    "@govcore/audit": "workspace:*",
    "@govcore/schema": "workspace:*",
    "@govcore/tenancy": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "next-auth": "^5.0.0-beta.25"
  },
  "peerDependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@auth/core": "0.41.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.0.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "tsup": "^8.3.0"
  },
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/logout-marker.ts",
      "src/password.ts",
      "src/types.ts",
      "src/password-flows.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
